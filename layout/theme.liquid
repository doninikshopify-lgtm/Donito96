<!DOCTYPE html>
<html lang="{{ shop.locale }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ shop.name }}</title>
  {{ content_for_header }}
</head>
<body>
  <header>
    <h1>{{ shop.name }}</h1>
    {{ 'header' | section }}
  </header>
  <main>
    {{ content }}
  </main>
  <footer>
    {{ 'footer' | section }}
  </footer>
</body>
</html>